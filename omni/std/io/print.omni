// style wraps `s` in an ANSI SGR escape sequence with the given code,
// followed by a reset. Use this for unusual codes (e.g. 256-color fg
// "38;5;208"); for common styles use the named helpers below.
func style(s:string, code:string):string {
    // INTRINSIC: wired to omni_io_style.
    return s
}

