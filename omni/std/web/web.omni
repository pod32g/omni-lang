// ============================================================================
// Routing
// ============================================================================

// server_get registers a GET route
func server_get(server:Server, pattern:string, handler:Handler) {
    let route = Route{
        method: "GET",
        pattern: pattern,
        handler: handler,
        middleware: [],
        route_group: nil
    }
    // Add route to server (simplified - would need proper array append)
}

// server_post registers a POST route
func server_post(server:Server, pattern:string, handler:Handler) {
    let route = Route{
        method: "POST",
        pattern: pattern,
        handler: handler,
        middleware: [],
        route_group: nil
    }
}

// server_put registers a PUT route
func server_put(server:Server, pattern:string, handler:Handler) {
    let route = Route{
        method: "PUT",
        pattern: pattern,
        handler: handler,
        middleware: [],
        route_group: nil
    }
}

// server_delete registers a DELETE route
func server_delete(server:Server, pattern:string, handler:Handler) {
    let route = Route{
        method: "DELETE",
        pattern: pattern,
        handler: handler,
        middleware: [],
        route_group: nil
    }
}

// server_patch registers a PATCH route
func server_patch(server:Server, pattern:string, handler:Handler) {
    let route = Route{
        method: "PATCH",
        pattern: pattern,
        handler: handler,
        middleware: [],
        route_group: nil
    }
}

// server_all registers a route that matches all HTTP methods
func server_all(server:Server, pattern:string, handler:Handler) {
    // Register for all methods
    server_get(server, pattern, handler)
    server_post(server, pattern, handler)
    server_put(server, pattern, handler)
    server_delete(server, pattern, handler)
    server_patch(server, pattern, handler)
}

// server_route registers a route with a custom HTTP method
func server_route(server:Server, method:string, pattern:string, handler:Handler) {
    let route = Route{
        method: method,
        pattern: pattern,
        handler: handler,
        middleware: [],
        route_group: nil
    }
}

// ============================================================================
// Route Groups
// ============================================================================

// server_group creates a new route group with a prefix
func server_group(server:Server, prefix:string):RouteGroup {
    return RouteGroup{
        prefix: prefix,
        middleware: [],
        routes: [],
        server: server
    }
}

// group_get registers a GET route in a group
func group_get(group:RouteGroup, pattern:string, handler:Handler) {
    let full_pattern = group.prefix + pattern
    server_get(group.server, full_pattern, handler)
}

// group_post registers a POST route in a group
func group_post(group:RouteGroup, pattern:string, handler:Handler) {
    let full_pattern = group.prefix + pattern
    server_post(group.server, full_pattern, handler)
}

// group_use adds middleware to a route group
func group_use(group:RouteGroup, middleware:Middleware) {
    // Add middleware to group (simplified)
}

// ============================================================================
// Context API
// ============================================================================

// context_param gets a path parameter value
// [IMPLEMENTED] Implemented in runtime
func context_param(ctx:Context, name:string):string {
    // This is an intrinsic function that will be wired to the runtime
    // during compilation. The actual implementation is in the backend.
    return std.collections.get(ctx.params, name)
}

// context_query gets a query parameter value
// [IMPLEMENTED] Implemented in runtime
func context_query(ctx:Context, name:string):string {
    return std.collections.get(ctx.query, name)
}

// context_query_all gets all query parameters
func context_query_all(ctx:Context):map<string, string> {
    return ctx.query
}

// context_header gets a request header value
func context_header(ctx:Context, name:string):string {
    return std.collections.get(ctx.request.headers, name)
}

// context_set_header sets a response header
func context_set_header(ctx:Context, name:string, value:string) {
    std.collections.set(ctx.response.headers, name, value)
}

// context_status sets the response status code
func context_status(ctx:Context, code:int) {
    ctx.response.status_code = code
    // Set default status text based on code
    if code == 200 {
        ctx.response.status_text = "OK"
    } else if code == 404 {
        ctx.response.status_text = "Not Found"
    } else if code == 500 {
        ctx.response.status_text = "Internal Server Error"
    }
}

// context_json sends a JSON response
func context_json(ctx:Context, data:any):Context {
    context_set_header(ctx, "Content-Type", "application/json")
    context_status(ctx, 200)
    // Convert data to JSON string (would use omni_json_stringify)
    ctx.response.body = ""  // Placeholder
    return ctx
}

// context_text sends a text response
func context_text(ctx:Context, text:string):Context {
    context_set_header(ctx, "Content-Type", "text/plain")
    context_status(ctx, 200)
    ctx.response.body = text
    return ctx
}

// context_html sends an HTML response
func context_html(ctx:Context, html:string):Context {
    context_set_header(ctx, "Content-Type", "text/html")
    context_status(ctx, 200)
    ctx.response.body = html
    return ctx
}

// context_file sends a file response
// [IMPLEMENTED] Implemented in runtime
func context_file(ctx:Context, path:string):Context {
    // This is an intrinsic function that will be wired to the runtime
    // during compilation. The actual implementation is in the backend.
    return ctx
}

// context_redirect sends a redirect response
func context_redirect(ctx:Context, url:string, code:int):Context {
    context_status(ctx, code)
    context_set_header(ctx, "Location", url)
    ctx.response.body = ""
    return ctx
}

// context_cookie sets a cookie
func context_cookie(ctx:Context, name:string, value:string, options:map<string, any>):Context {
    let cookie_value = name + "=" + value
    // Add options (path, domain, expires, etc.)
    context_set_header(ctx, "Set-Cookie", cookie_value)
    return ctx
}

// context_get_cookie gets a cookie value from the request
func context_get_cookie(ctx:Context, name:string):string {
    let cookie_header = context_header(ctx, "Cookie")
    if cookie_header == "" {
        return ""
    }
    // Parse cookie header (simplified)
    return ""
}

// context_body gets the request body
func context_body(ctx:Context):string {
    return ctx.body
}

