// middleware_logger logs requests
func middleware_logger(ctx:Context):Context {
    std.io.println("[" + std.time.now_string() + "] " + ctx.request.method + " " + ctx.request.url)
    return ctx
}

// middleware_cors adds CORS headers
func middleware_cors(ctx:Context, options:map<string, any>):Context {
    context_set_header(ctx, "Access-Control-Allow-Origin", "*")
    context_set_header(ctx, "Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
    context_set_header(ctx, "Access-Control-Allow-Headers", "Content-Type")
    return ctx
}

// middleware_json_parser parses JSON request body
func middleware_json_parser(ctx:Context):Context {
    let content_type = context_header(ctx, "Content-Type")
    if std.string.contains(content_type, "application/json") {
        ctx.body = context_body(ctx)
        // Parse JSON (would use omni_json_parse)
    }
    return ctx
}

// middleware_form_parser parses form request body
func middleware_form_parser(ctx:Context):Context {
    let content_type = context_header(ctx, "Content-Type")
    if std.string.contains(content_type, "application/x-www-form-urlencoded") {
        // Parse form data (would use omni_http_parse_form_urlencoded)
    }
    return ctx
}

