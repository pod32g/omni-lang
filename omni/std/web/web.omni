// server_create creates a new server instance
// [IMPLEMENTED] Implemented in runtime
func server_create(port:int, options:map<string, any>):Server {
    // This is an intrinsic function that will be wired to the runtime
    // during compilation. The actual implementation is in the backend.
    return Server{
        port: port,
        routes: [],
        middleware: [],
        connection_pool: nil,
        thread_pool: nil,
        config: options
    }
}

