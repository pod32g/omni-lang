// std.web - HTTP Server Framework for OmniLang
// Express.js/Gin-style web framework

import std

// ============================================================================
// Core Structures
// ============================================================================

// Server represents an HTTP server instance
struct Server {
    port:int
    routes:array<Route>
    middleware:array<Middleware>
    connection_pool:any  // Will be connection pool handle
    thread_pool:any      // Will be thread pool handle
    config:map<string, any>
}

// Route represents a single route definition
struct Route {
    method:string
    pattern:string
    handler:Handler
    middleware:array<Middleware>
    route_group:any  // Optional route group
}

// RouteGroup represents a group of routes with a common prefix
struct RouteGroup {
    prefix:string
    middleware:array<Middleware>
    routes:array<Route>
    server:Server
}

// Context represents the request/response context
struct Context {
    request:std.network.HTTPRequest
    response:std.network.HTTPResponse
    params:map<string, string>
    query:map<string, string>
    body:string
    session:any  // Session data
    user:any    // Authenticated user
    state:map<string, any>  // Custom state
}

// Handler type: function that processes a request and returns a response
type Handler = (Context) -> Context | Promise<Context>

// Middleware type: function that processes context and returns modified context
type Middleware = (Context) -> Context | Promise<Context>

// WebSocket represents a WebSocket connection
struct WebSocket {
    socket:int
    connection:any
}

// UploadedFile represents an uploaded file
struct UploadedFile {
    name:string
    filename:string
    content_type:string
    size:int
    data:string
    path:string
}

