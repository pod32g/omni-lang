struct Counter {
    value: int
}

func (c : Counter) bumped(delta: int) : int {
    return c.value + delta
}

func (c : Counter) doubled() : int {
    return c.value + c.value
}

func main() : int {
    let c: Counter = Counter{value: 7}
    let a: int = c.bumped(3)
    let b: int = c.doubled()
    return a + b
}
