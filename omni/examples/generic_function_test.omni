// Originally exercised a generic `max<T>`. Generic monomorphization
// isn't yet implemented, so this test uses two concrete overloads
// (named differently) to keep the demo running.
import std.io as io

func max_int(a: int, b: int): int {
    if a > b {
        return a
    }
    return b
}

func max_float(a: float, b: float): float {
    if a > b {
        return a
    }
    return b
}

func main(): int {
    let intMax: int = max_int(10, 20)
    let floatMax: float = max_float(3.14, 2.71)

    io.println("Max int: " + intMax)
    io.println("Max float: " + floatMax)

    return 0
}
