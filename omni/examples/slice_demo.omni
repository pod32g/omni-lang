import std

func main() : int {
    var xs: []int = [1, 2, 3]
    xs = append(xs, 4)
    xs = append(xs, 5)

    // xs is now [1,2,3,4,5]; take the middle three → [2,3,4]
    let mid: []int = xs[1:4]

    // Front slice (default low): [1,2,3]
    let head: []int = xs[:3]

    // Back slice (default high): [4,5]
    let tail: []int = xs[3:]

    // Sum xs[0] + mid[1] + head[2] + tail[0] = 1 + 3 + 3 + 4 = 11
    return xs[0] + mid[1] + head[2] + tail[0]
}
