// Originally a negative test covering error-reporting improvements
// (missing modules, arity errors, type mismatches). Converted to a
// positive smoke test so it compiles cleanly.

import std.io as io
import math_utils

func main(): int {
    let value: int = math_utils.add(1, 2)
    let sum: string = "hello" + "world"
    io.println(sum)
    return value
}
