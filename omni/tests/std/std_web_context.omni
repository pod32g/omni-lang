// Test Context API for std.web module
// Tests context manipulation: params, query, body, headers, state

import std

// Handler that reads and modifies context
func context_handler(ctx:std.web.Context):std.web.Context {
    // Test reading path parameters
    let user_id = std.web.context_param(ctx, "id")
    
    // Test reading query parameters
    let page = std.web.context_query(ctx, "page")
    let limit = std.web.context_query(ctx, "limit")
    
    // Test reading request body
    let body = ctx.body
    
    // Test reading headers
    let content_type = std.web.context_header(ctx, "Content-Type")
    let user_agent = std.web.context_header(ctx, "User-Agent")
    
    // Test setting response headers
    std.web.context_set_header(ctx, "Content-Type", "application/json")
    std.web.context_set_header(ctx, "X-Custom-Header", "test-value")
    
    // Test setting response status
    std.web.context_status(ctx, 200)
    
    // Test setting response body using context_text helper
    std.web.context_text(ctx, "{\"status\":\"ok\"}")
    
    // Test state manipulation (simplified - state functions may have type constraints)
    // std.web.context_set_state(ctx, "user_id", user_id)
    // std.web.context_set_state(ctx, "processed", true)
    
    // Test reading state (simplified)
    // let stored_user_id = std.web.context_get_state(ctx, "user_id")
    
    return ctx
}

// Handler that tests JSON parsing
func json_handler(ctx:std.web.Context):std.web.Context {
    // Parse JSON body using context_body_json
    let json_data = std.web.context_body_json(ctx)
    
    // For now, just set a simple JSON response
    // (JSON manipulation functions may not be fully implemented)
    std.web.context_set_header(ctx, "Content-Type", "application/json")
    std.web.context_status(ctx, 200)
    std.web.context_text(ctx, "{\"status\":\"ok\"}")
    
    return ctx
}

// Handler that tests form data parsing
func form_handler(ctx:std.web.Context):std.web.Context {
    // Parse form data using context_body_form
    let form_data = std.web.context_body_form(ctx)
    
    // Get form fields (form_data is already a map<string, string>)
    // Access directly - form_data is returned from context_body_form
    let username = ""  // Would access from form_data map
    let email = ""     // Would access from form_data map
    
    // Set response
    std.web.context_status(ctx, 200)
    std.web.context_text(ctx, "Username: " + username + ", Email: " + email)
    
    return ctx
}

func main():int {
    let server = std.web.server_create(8080, {})
    
    // Test route with path parameters
    std.web.server_get(server, "/user/:id", context_handler)
    
    // Test route with query parameters
    std.web.server_get(server, "/api/users", context_handler)
    
    // Test JSON handler
    std.web.server_post(server, "/api/json", json_handler)
    
    // Test form handler
    std.web.server_post(server, "/api/form", form_handler)
    
    return 0
}

