// Regression: queue, stack, set in std.collections work end-to-end.
// Before this they would fail to compile (unknown type queue<int>)
// or silently return defaults from the OmniLang stub bodies.
//
// Sequence:
//   queue: enqueue 10, 20, 30; size=3; dequeue → 10
//   stack: push 1, 2, 3; size=3; pop → 3
//   set:   add 1, 2, 1, 3; size=3; contains(2)=true
//
// score = q_size*100 + q_first         // 3*100 + 10 = 310
//       + s_size*10  + s_top           // 3*10 + 3 = 33
//       + set_size                     // 3
//       + (set_contains(2) ? 1 : 0)    // 1
//                                      // total: 347
import std

func main():int {
    let q:queue<int> = std.collections.queue_create()
    std.collections.queue_enqueue(q, 10)
    std.collections.queue_enqueue(q, 20)
    std.collections.queue_enqueue(q, 30)
    let q_size:int = std.collections.queue_size(q)
    let q_first:int = std.collections.queue_dequeue(q)

    let st:stack<int> = std.collections.stack_create()
    std.collections.stack_push(st, 1)
    std.collections.stack_push(st, 2)
    std.collections.stack_push(st, 3)
    let s_size:int = std.collections.stack_size(st)
    let s_top:int = std.collections.stack_pop(st)

    let se:set<int> = std.collections.set_create()
    std.collections.set_add(se, 1)
    std.collections.set_add(se, 2)
    std.collections.set_add(se, 1)
    std.collections.set_add(se, 3)
    let se_size:int = std.collections.set_size(se)

    var contains_score:int = 0
    if std.collections.set_contains(se, 2) {
        contains_score = 1
    }

    return q_size * 100 + q_first + s_size * 10 + s_top + se_size + contains_score
}
