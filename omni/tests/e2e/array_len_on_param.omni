// Regression: len(arr) now works on a function parameter. Before the
// implicit-length-companion ABI change, the C backend emitted a
// "length unknown" warning and len(arr) returned -1 inside callees.
//
// Sums [10, 20, 30, 40] = 100.
import std

func array_sum(xs:array<int>):int {
    var total:int = 0
    var i:int = 0
    let n:int = len(xs)
    while i < n {
        total = total + xs[i]
        i = i + 1
    }
    return total
}

func main():int {
    let arr:array<int> = [10, 20, 30, 40]
    return array_sum(arr)
}
