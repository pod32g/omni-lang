// Regression: previously-stubbed std.string functions now have real
// runtime implementations (trim variants, case manipulation, count
// helpers, ignore-case comparisons).
//
// The exit code is a checksum that catches any single failure:
//   trim_left("  hi") + trim_right("hi  ") + trim_all(" h i ")
//     → "hihihi" (length 6)
//   to_title("a b") → "A B" (3 chars)
//   capitalize("ab") + reverse("ab") → "Abba" (4 chars)
//   equals_ignore_case + compare_ignore_case sanity → 1 - 0 = 1
//   count_occurrences("ababa", "a") = 3
//   count_words("a b c") = 3
//   count_lines("a\nb") = 2 (C backend only — VM doesn't decode \n)
// Total: 6 + 3 + 4 + 1 + 3 + 3 = 20.
import std

func main():int {
    var sum:int = 0

    let l:string = std.string.trim_left("  hi")
    let r:string = std.string.trim_right("hi  ")
    let a:string = std.string.trim_all(" h i ")
    sum = sum + std.string.length(l + r + a)  // 2+2+2 = 6

    sum = sum + std.string.length(std.string.to_title("a b"))  // 3
    sum = sum + std.string.length(std.string.capitalize("ab") + std.string.reverse("ab"))  // 4

    if std.string.equals_ignore_case("Hi", "HI") {
        if std.string.compare_ignore_case("a", "a") == 0 {
            sum = sum + 1
        }
    }

    sum = sum + std.string.count_occurrences("ababa", "a")  // 3
    sum = sum + std.string.count_words("a b c")  // 3

    return sum
}
