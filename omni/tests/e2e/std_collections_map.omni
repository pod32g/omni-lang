// Regression: std.collections.{size, get, set, has, remove, clear}
// now have real implementations on both backends. The runtime
// functions live in omni_map_*; the C generator routes
// std.collections.* through the intrinsic name table; the VM has
// matching execIntrinsic cases. The OmniLang stub bodies are still
// there but the VM tail-call detector skips into them.
//
// Sequence:
//   m = {"a": 10, "b": 20}
//   size(m) = 2
//   get(m, "a") = 10
//   has(m, "b") = true → +1
//   set(m, "c", 30); size(m) = 3
//   remove(m, "a") = true → +1
//   has(m, "a") = false → no add
//   size(m) = 2
//   clear(m); size(m) = 0
//
// Total: 2 + 10 + 1 + 3 + 1 + 2 + 0 = 19
import std

func main():int {
    var sum:int = 0
    var m:map<string, int> = {"a": 10, "b": 20}

    sum = sum + std.collections.size(m)        // +2
    sum = sum + std.collections.get(m, "a")    // +10
    if std.collections.has(m, "b") {
        sum = sum + 1                           // +1
    }

    std.collections.set(m, "c", 30)
    sum = sum + std.collections.size(m)        // +3

    if std.collections.remove(m, "a") {
        sum = sum + 1                           // +1
    }

    sum = sum + std.collections.size(m)        // +2

    std.collections.clear(m)
    sum = sum + std.collections.size(m)        // +0

    return sum
}
